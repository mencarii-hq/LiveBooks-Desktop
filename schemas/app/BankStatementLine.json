        { "value": "unmatched", "label": "Unmatched" },
        { "value": "matched", "label": "Matched" },
        { "value": "ignored", "label": "Ignored" }
      ]
    },
    {
      "fieldname": "matchedReferenceType",
      "label": "Matched ref. type",
